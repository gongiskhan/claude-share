{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["verdict", "summary", "findings"],
  "properties": {
    "verdict": {
      "type": "string",
      "enum": ["approve", "needs-attention"],
      "description": "approve = Codex can find no material reason to block this slice. needs-attention = at least one material, defensible risk remains."
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "description": "Terse ship / no-ship assessment of the slice changes."
    },
    "findings": {
      "type": "array",
      "description": "Material adversarial findings only. Empty when verdict is approve.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["severity", "title", "file", "line_start", "line_end", "recommendation", "confidence"],
        "properties": {
          "severity": { "type": "string", "enum": ["critical", "high", "medium", "low"] },
          "title": { "type": "string", "minLength": 1 },
          "file": { "type": "string", "minLength": 1 },
          "line_start": { "type": "integer", "minimum": 1 },
          "line_end": { "type": "integer", "minimum": 1 },
          "recommendation": { "type": "string", "minLength": 1 },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    }
  }
}
